# ============================================================
# AI Job Search & Resume Automation Platform - environment vars
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Database ---
POSTGRES_USER=jobplatform
POSTGRES_PASSWORD=change_me
POSTGRES_DB=jobplatform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://jobplatform:change_me@postgres:5432/jobplatform

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- AI Providers (configure at least one; OpenAI is default) ---
AI_PROVIDER=openai            # openai | anthropic | gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Storage (choose one) ---
STORAGE_BACKEND=s3            # s3 | cloudinary
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=job-platform-documents
CLOUDINARY_URL=

# --- Notifications ---
# Email (SMTP or SES)
EMAIL_BACKEND=smtp            # smtp | ses
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=notifications@yourdomain.com

# WhatsApp (Twilio WhatsApp Business API)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
NOTIFY_WHATSAPP_TO=whatsapp:+1XXXXXXXXXX

# Browser push (VAPID keys for Web Push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# --- Job source connectors (compliant, public endpoints) ---
# ATS aggregator APIs (no key required for public job boards, but some
# orgs require a board token - see docs/JOB_SOURCES.md)
GREENHOUSE_BOARD_TOKENS=      # comma separated company board tokens
LEVER_COMPANY_SLUGS=          # comma separated
ASHBY_JOB_BOARD_NAMES=        # comma separated
SMARTRECRUITERS_COMPANY_IDS=  # comma separated
WORKDAY_TENANTS=              # comma separated tenant configs, see docs

# Manual-assist only sources (search aggregation via official APIs where
# available; automated application submission is NOT performed on these
# platforms because their Terms of Service prohibit it)
INDEED_PUBLISHER_ID=

# --- App ---
ENVIRONMENT=development
SECRET_KEY=change_me_to_a_random_secret
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
JOB_SCAN_INTERVAL_MINUTES=30
JOB_MAX_AGE_HOURS=24
